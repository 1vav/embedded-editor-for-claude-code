    {
      "id": "viewer-text",
      "type": "text",
      "x": 514,
      "y": 196,
      "width": 408,
      "height": 265,
      "text": "Viewer Server  (http://127.0.0.1:3000)\n──────────────────────────────────────\nGET  /api/diagrams   /api/notes\n     /api/tldraw\nPUT  /api/diagram/:name   (CRUD)\n     /api/note/:name\n     /api/tldraw/:name\nGET  /api/svg/:name   /api/png/:name\n     /api/history/:name\nGET  /events          (SSE live sync)\n\nMedia: serves *.png *.jpg *.svg…\nfrom CWD for markdown image embeds",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7c2d12",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 1009,
      "version": 1,
      "versionNonce": 1009,
      "isDeleted": false,
      "groupIds": [],
