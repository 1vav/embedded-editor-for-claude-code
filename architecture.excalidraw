      "locked": false,
      "containerId": null,
      "originalText": "MCP Server\n──────────────────────────────────\nlist_diagrams\ncreate_diagram\nread_diagram\nwrite_diagram\nappend_elements\ndelete_diagram\n\nRender pipeline:\n  Excalidraw.exportToSvg()\n  → @resvg/resvg-js\n  → PNG base64  →  inline in chat",
      "autoResize": true,
      "lineHeight": 1.5,
