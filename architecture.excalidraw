      "roundness": null,
      "boundElements": [],
      "updated": 0,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "Viewer Server  (http://127.0.0.1:3000)\n──────────────────────────────────────\nGET  /api/diagrams   /api/notes\n     /api/tldraw\nPUT  /api/diagram/:name   (CRUD)\n     /api/note/:name\n     /api/tldraw/:name\nGET  /api/svg/:name   /api/png/:name\n     /api/history/:name\nGET  /events          (SSE live sync)\n\nMedia: serves *.png *.jpg *.svg…\nfrom CWD for markdown image embeds",
      "autoResize": true,
      "lineHeight": 1.5,
      "index": "a8"
