{
  "name": "embedded-editor-for-claude-code",
  "version": "1.4.5",
  "description": "Embedded visual workspace for Claude Code — Excalidraw diagrams (with MCP tools + inline PNG), tldraw canvases, and Markdown notes, all linked by wikilinks",
  "license": "MIT",
  "author": {
    "name": "1vav",
    "url": "https://github.com/1vav"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1vav/embedded-editor-for-claude-code.git"
  },
  "homepage": "https://github.com/1vav/embedded-editor-for-claude-code#readme",
  "bugs": {
    "url": "https://github.com/1vav/embedded-editor-for-claude-code/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "mcp",
    "model-context-protocol",
    "excalidraw",
    "tldraw",
    "markdown",
    "diagram",
    "visual-editor",
    "ai-tools"
  ],
  "type": "module",
  "bin": {
    "embedded-editor": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "vendor/",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/cli.js serve",
    "init": "node bin/cli.js init",
    "build:excalidraw": "node scripts/build-excalidraw-bundle.mjs",
    "build:viewer": "node scripts/build-viewer-bundle.mjs",
    "build:viewer:fast": "node scripts/build-viewer-bundle.mjs --no-compress",
    "build": "node scripts/build-excalidraw-bundle.mjs && node scripts/build-viewer-bundle.mjs",
    "prepublishOnly": "node scripts/build-excalidraw-bundle.mjs && node scripts/build-viewer-bundle.mjs",
    "lint": "eslint src/ bin/ scripts/",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint",
    "bin/**/*.js": "eslint",
    "scripts/**/*.mjs": "eslint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@resvg/resvg-js": "^2.6.2",
    "chalk": "^5.3.0",
    "duckdb": "^1.4.4",
    "glob": "^13.0.6",
    "jsdom": "^29.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "lodash-es": "^4.18.1",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@eslint/js": "^9.39.4",
    "@excalidraw/excalidraw": "^0.18.0",
    "@marp-team/marp-core": "^4.3.0",
    "@tldraw/tldraw": "^4.5.9",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdown-it": "^14.1.1",
    "react": "^19.2.5",
    "react-dom": "^18.3.1"
  }
}
